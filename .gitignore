# Dependencies
node_modules/

# Build outputs
dist/
dist-electron/

# TypeScript compiled output
*.js.map
*.d.ts.map

# WebUI compiled JavaScript (generated by build:webui)
src/webui/static/*.js

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# TypeScript build / cache
*.tsbuildinfo
lib/
# But allow lib/ directories inside src/ (e.g., video-rtc.js)
!src/**/lib/

# SwiftPM build output
.build/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# npm configuration with tokens
.npmrc

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Playwright test artifacts
test-results/

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Electron dist
out/

# Vendored runtime package files required by @parallel-7/slicer-meta
!vendor/slicer-meta/dist/
!vendor/slicer-meta/dist/**

# go2rtc binaries (downloaded at build time via postinstall)
resources/bin/


# AI Agent Files
.kiro/
.agents/
.claude/
.codex/
.pi/
!native/FlashForgeUI/.codex/
!native/FlashForgeUI/.codex/environments/
!native/FlashForgeUI/.codex/environments/environment.toml

# GitHub Actions release workflow omitted from this compatibility fork.
.github/workflows/

# Misc scripts and other files
*.py
detail_response_example.json
debug_logs/*
.genkit/

# Temporary test/development artifacts
.tmp-ff-api/
hook_debug_log.txt
__pycache__/
.pi/session-memory.json
