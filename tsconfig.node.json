{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "src/renderer/src/ui/settings/types/**/*"
  ],
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".cache/tsbuildinfo/tsconfig.node.tsbuildinfo",
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@renderer/*": ["./src/renderer/src/*"]
    }
  }
}
